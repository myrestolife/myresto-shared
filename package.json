{
  "name": "@myresto/shared",
  "version": "2.1.0",
  "description": "Shared utilities and components for MyResto Next.js apps",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myrestolife/myresto-shared.git"
  },
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./lib/*": "./lib/*.ts",
    "./lib/auth": "./lib/auth/index.tsx",
    "./lib/authorization": "./lib/authorization.tsx",
    "./lib/theme": "./lib/theme.tsx",
    "./lib/brand": "./lib/brand.ts",
    "./lib/config": "./lib/config.ts",
    "./lib/api": "./lib/api.ts",
    "./lib/server-auth": "./lib/server-auth/index.ts",
    "./components/*": "./components/*.tsx",
    "./components/Footer": "./components/Footer.tsx",
    "./components/ErrorBoundary": "./components/ErrorBoundary.tsx",
    "./components/Toast": "./components/Toast.tsx",
    "./components/Spinner": "./components/Spinner.tsx",
    "./components/EmptyState": "./components/EmptyState.tsx",
    "./lib/timeAgo": "./lib/timeAgo.ts",
    "./lib/middleware": "./lib/middleware.ts",
    "./lib/r2": "./lib/r2.ts",
    "./lib/ratelimit": "./lib/ratelimit.ts",
    "./components/NavbarShell": "./components/NavbarShell.tsx",
    "./components/AuthPageLayout": "./components/AuthPageLayout.tsx",
    "./components/Navbar": "./components/Navbar.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "build": "tsup"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3",
    "@supabase/supabase-js": ">=2",
    "@upstash/ratelimit": ">=2",
    "@upstash/redis": ">=1",
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@upstash/ratelimit": {
      "optional": true
    },
    "@upstash/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@supabase/supabase-js": "^2.100.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^26.0.0",
    "next": "^15.0.0",
    "prettier": "^3.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@supabase/ssr": "^0.9.0"
  }
}
